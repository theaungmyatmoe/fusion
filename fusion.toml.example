# Fusion — mobile-first AI coding agent
# Config file (Codex-style TOML, primary format)
#
# Place this at:
#   ./fusion.toml           (project-level, highest priority)
#   ~/.config/fusion/fusion.toml  (global)
#   ~/.fusion/fusion.toml   (global fallback)
#
# Environment variables always override file config.
# Also supports zencode.json (JSON) for backward compatibility.

# Model to use (default: Kimi 2.7 Code via Cloudflare Workers AI)
model = "@cf/moonshotai/kimi-k2.7-code"
# small_model = "@cf/moonshotai/kimi-k2.7-code"

# Auto-approve all tool actions (use carefully!)
yolo = false

[provider]
# Which provider to use by default: "cloudflare", "xai", "openai", "auto"
default = "cloudflare"

# Uncomment and fill in real values (template placeholders are ignored by the loader).
# Prefer ~/.config/fusion/fusion.toml for secrets, or env vars:
#   CLOUDFLARE_ACCOUNT_ID / CLOUDFLARE_API_TOKEN / XAI_API_KEY
#
# [provider.cloudflare]
# account_id = "your_cloudflare_account_id"
# api_key = "your_cloudflare_api_token"
#
# [provider.xai]
# api_key = "xai-your-key"
# base_url = "https://api.x.ai/v1"
#
# [provider.openai]
# api_key = "sk-your-key"
# base_url = "https://api.openai.com/v1"

[settings]
# theme = "system"

# Agent runtime tuning. Sub-agent responses stream through the same API event path
# as the parent. Keep the child focused and bounded for fast failure recovery.
# agent_max_rounds = 25
# agent_pacing_ms = 150          # delay between parent tool rounds (0 disables)
# subagent_pacing_ms = 200       # delay between sub-agent tool rounds
# subagent_max_rounds = 12
# subagent_max_tokens = 16384
# subagent_timeout_secs = 900
# subagent_verify_timeout_secs = 120
#
# Swarm / rate-limit controls (prevents 429 when spawning sub-agents).
# Defaults are provider-aware (Cloudflare is strictest). Explicit values override.
# swarm_max_concurrency = 2     # max parallel sub-agents (worker-pool queue)
# swarm_spawn_stagger_ms = 750  # base pause between starting queued jobs (grows under 429 pressure)
# llm_max_concurrent = 2        # process-wide concurrent LLM HTTP requests (live-updatable)
